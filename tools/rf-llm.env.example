# Copy the relevant lines into your shell before running the skill, e.g. in PowerShell:
#   $env:RF_LLM_PROVIDER = "gemini"
#   $env:RF_LLM_MODEL    = "gemini-2.5-flash"
#   $env:GEMINI_API_KEY  = "..."
#
# Only ONE provider needs to be configured at a time. Leaving RF_LLM_PROVIDER
# unset keeps the skill in its normal (non-delegated) datasheet-reading flow.

# --- pick a provider ---------------------------------------------------------
# openai | gemini | local | mock
RF_LLM_PROVIDER=gemini

# --- model for that provider -------------------------------------------------
# openai:  gpt-4o, gpt-4o-mini, ...
# gemini:  gemini-2.5-flash, gemini-2.5-pro, gemini-3.5-flash, ...
# local:   qwen3:8b, llama3.1:8b, ... (must be pulled in Ollama)
RF_LLM_MODEL=gemini-2.5-flash

# --- credentials (only the one for your chosen provider is needed) -----------
OPENAI_API_KEY=
GEMINI_API_KEY=

# --- local (Ollama) provider only -------------------------------------------
RF_LLM_OLLAMA_URL=http://localhost:11434
